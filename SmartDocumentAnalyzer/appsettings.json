


{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // "Mock" = local analysis, no API key needed (default, use for demos/portfolio)
  // "Claude" = Anthropic Claude API (set Anthropic:ApiKey below or in User Secrets)
  "AnalysisProvider": "Mock",

  "Anthropic": {
    "ApiKey": "YOUR_API_KEY_HERE"
  }
}
